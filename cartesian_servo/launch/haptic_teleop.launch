<launch>
  <!-- ================================================================
       Cartesian Servo + Haptic Teleop — Python node version

       All-in-one: haptic bridge + smoothing + IK streaming.
       No OROCOS component = no semaphore issues.

       Uruchomienie:
         roslaunch cartesian_servo haptic_teleop.launch
       ================================================================ -->

  <node name="cartesian_servo" pkg="cartesian_servo" type="cartesian_servo_node.py"
        output="screen" respawn="false">

    <!-- ===== Haptic device topics ===== -->
    <param name="haptic_pose_topic"   value="/phantom/pose"/>
    <param name="haptic_button_topic" value="/phantom/button"/>
    <param name="robot_pose_topic"    value="/es_arm/cartesian_pose"/>
    <param name="servo_command_topic" value="/es_cartesian_servo/command"/>

    <!-- ===== Smoothing ===== -->
    <param name="publish_rate"          value="250.0"/>
    <param name="smoothing_alpha"       value="0.85"/>
    <param name="decel_smoothing_alpha" value="0.98"/>
    <param name="watchdog_timeout_ms"   value="200.0"/>
    <param name="idle_velocity_threshold" value="0.001"/>

    <!-- ===== Velocity limits ===== -->
    <param name="max_linear_speed"  value="0.5"/>
    <param name="max_angular_speed" value="1.0"/>

    <!-- ===== Haptic scaling ===== -->
    <!-- Phantom Omni ~160mm workspace, ES5 ~820mm reach
         scale 3.0 = 160mm joystick = 480mm robot -->
    <param name="scale_position"    value="3.0"/>
    <param name="scale_orientation" value="1.0"/>
    <param name="dead_zone"         value="0.002"/>

    <!-- ===== Frame alignment ===== -->
    <!-- RPY [rad]: rotate haptic frame to robot base frame -->
    <rosparam param="frame_rotation_rpy">[0.0, 0.0, 0.0]</rosparam>
  </node>
</launch>
