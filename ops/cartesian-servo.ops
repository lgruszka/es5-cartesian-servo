//------------------------------------------------------------------------------
// CartesianServo — Cartesian streaming servo component
//
// Komponent dziala STANDALONE (wlasny watek 500 Hz, jak ESImpedance),
// NIE w SorterScheme.
//
// Wymagane zmiany w es5-hardware.ops:
//   1. Zakomentuj linie 257:
//      //connect("ESPoseInt.CartesianPositionCommand", "IK.InputEndEffectorPose", ConnPolicy())
//   2. Dodaj PRZED "ESHandGuiding.start()" (okolo linii 952):
//      runScript( ros.find("es5_bringup") + "/cartesian-servo.ops")
//
// Tryb pozycyjny (CSP, mode 8) — domyslny:
//   Pose -> CartesianServo -> IK -> LimitDetector -> ESJ2M -> Motors
//
// Tryb momentowy (CST, mode 4) — odkomentuj sekcje TORQUE MODE ponizej
//------------------------------------------------------------------------------

//------------------------------------------------------------------------------
//-- Load component (standalone, own RT thread at 500 Hz)
//------------------------------------------------------------------------------

loadComponent("ESCartesianServo", "CartesianServo")
setActivity("ESCartesianServo", 0.002, 2, ORO_SCHED_RT)
ESCartesianServo.configure()

//------------------------------------------------------------------------------
//-- Connections
//------------------------------------------------------------------------------

// Input: current end-effector pose from FK (feedback)
connect("FK.EndEffectorOutputPose", "ESCartesianServo.CartesianPosition", ConnPolicy())

// Input: current joint positions (for IK differentiation seed)
connect("ESM2J.JointPosition", "ESCartesianServo.JointPosition", ConnPolicy())

// Input: streaming Cartesian commands from ROS topic
stream("ESCartesianServo.CartesianCommand", ros.comm.topic("/es_cartesian_servo/command"))

// Input: IK failure signal
connect("IK.ikSolutionStopRobot", "ESCartesianServo.IkFailure", ConnPolicy())

// Input: stop from StopDetector (Int32, non-zero = stop)
connect("ESStopDetector.stopRobot", "ESCartesianServo.CancelServo", ConnPolicy())

// Output: smoothed Cartesian pose -> IK (REPLACES ESPoseInt -> IK)
connect("ESCartesianServo.CartesianPositionCommand", "IK.InputEndEffectorPose", ConnPolicy())

// Output: Cartesian velocity (monitoring)
stream("ESCartesianServo.CartesianVelocity", ros.comm.topic("/es_cartesian_servo/velocity"))

// Output: servo status (monitoring)
stream("ESCartesianServo.ServoActive", ros.comm.topic("/es_cartesian_servo/active"))
stream("ESCartesianServo.ServoStatus", ros.comm.topic("/es_cartesian_servo/status"))

// Online parameter tuning
stream("ESCartesianServo.new_smoothing_alpha", ros.comm.topic("/es_cartesian_servo/smoothing_alpha"))
stream("ESCartesianServo.new_max_linear_speed", ros.comm.topic("/es_cartesian_servo/max_linear_speed"))
stream("ESCartesianServo.new_max_angular_speed", ros.comm.topic("/es_cartesian_servo/max_angular_speed"))
stream("ESCartesianServo.new_watchdog_timeout", ros.comm.topic("/es_cartesian_servo/watchdog_timeout"))
stream("ESCartesianServo.new_torque_mode", ros.comm.topic("/es_cartesian_servo/torque_mode"))
stream("ESCartesianServo.new_debug", ros.comm.topic("/es_cartesian_servo/debug"))

//------------------------------------------------------------------------------
//-- Start (standalone, NOT in SorterScheme)
//-- startHook() toleruje brak danych z FK — zainicjalizuje sie przy pierwszym
//-- odczycie w updateHook
//------------------------------------------------------------------------------

ESCartesianServo.start()

//------------------------------------------------------------------------------
//-- TORQUE MODE (odkomentuj gdy uzywasz CST z ESImpedance)
//-- Wymaga:
//--   1. Aktywacja ESImpedance w es5-hardware.ops (linie 863-871)
//--   2. ModeOfOperation = 4 (CST) na wszystkich jointach
//------------------------------------------------------------------------------
